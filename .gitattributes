# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Dart/Flutter lock files should always use LF (generated by pub)
*.lock text eol=lf

# PowerShell scripts should use LF (consistent across environments)
*.ps1 text eol=lf

# Shell scripts should use LF
*.sh text eol=lf

# Windows batch files should use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files (no normalization)
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.dll binary
*.exe binary
*.so binary
*.dylib binary